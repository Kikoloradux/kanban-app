{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/dbal": "^3.0",
        "doctrine/doctrine-bundle": "^2.0",
        "doctrine/doctrine-migrations-bundle": "^3.0",
        "doctrine/orm": "^2.0",
        "lexik/jwt-authentication-bundle": "^2.0",
        "nelmio/cors-bundle": "^2.6",
        "symfony/console": "6.4.*",
        "symfony/dotenv": "6.4.*",
        "symfony/form": "6.4.*",
        "symfony/framework-bundle": "6.4.*",
        "symfony/lock": "^7.4",
        "symfony/mailer": "6.4.*",
        "symfony/rate-limiter": "^8.1",
        "symfony/runtime": "^6.4",
        "symfony/security-bundle": "6.4.*",
        "symfony/twig-bundle": "6.4.*",
        "symfony/validator": "^7.4",
        "symfony/var-exporter": "^6.4",
        "symfony/yaml": "6.4.*",
        "twig/extra-bundle": "^2.12|^3.24",
        "twig/twig": "^2.12|^3.27"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-install-cmd": [],
        "post-update-cmd": []
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "6.4.*"
        }
    }
}
